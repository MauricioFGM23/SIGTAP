"dados/base_ambulatorial.csv",
sep = ";",                          # csv2 = separador ;
dec = ",",                          # csv2 = decimal ,
select = c("ano", "procedimento", "quantidade_corrigida"),  # só 3 colunas
colClasses = c(
ano = "integer",
procedimento = "numeric",
quantidade_corrigida = "numeric"
)
)
